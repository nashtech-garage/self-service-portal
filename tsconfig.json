{
  "extends": "@backstage/cli/config/tsconfig.json",
  "include": [
    "packages/*/src",
    "plugins/*/src",
    "plugins/*/dev",
    "plugins/*/migrations"
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "paths": {
      "@backstage/plugin-auth-node": [
        "./node_modules/@backstage/plugin-auth-node"
      ]
    },
    "typeRoots": [
      "node_modules/@types"
    ]
  }
}